{
  "name": "repo-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that audits a repository against health/governance checks (read-only).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && ncc build src/main.ts -o dist --source-map --license licenses.txt --minify",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "package": "npm run build"
  },
  "keywords": ["github-action", "audit", "governance", "repo-health"],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/request-error": "^6.1.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
